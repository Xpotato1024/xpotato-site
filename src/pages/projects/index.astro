---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import Card from "../../components/ui/Card.astro";
import { getPublishedEntries } from "../../lib/content";

const projects = await getPublishedEntries("projects");
---

<BaseLayout title="Projects" description="公開サイト、移行設計、ブラウザ内アプリを整理するプロジェクト一覧。">
  <Container className="py-16">
    <SectionHeading
      eyebrow="Projects"
      title="プロジェクト"
      description="実装単位をプロジェクトとして残し、コード以外の文脈も MDX 側に集約します。"
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-2">
      {
        projects.map((project) => (
          <Card href={`/projects/${project.slug}/`}>
            <p class="text-sm text-ink/55">{project.data.status}</p>
            <h3 class="mt-3 font-display text-2xl text-ink">{project.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink/72">{project.data.summary}</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {project.data.technologies.map((item) => <li class="rounded-full bg-accent/10 px-3 py-1 text-xs text-accent">{item}</li>)}
            </ul>
          </Card>
        ))
      }
    </div>
  </Container>
</BaseLayout>
