---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import ProjectVisual from "../../components/project/ProjectVisual.astro";
import { getPublishedEntries } from "../../lib/content";
import { formatDate } from "../../lib/date";
import { getRepoLinkLabel, hasVisibleRepoLink } from "../../lib/projects";

const projects = await getPublishedEntries("projects");

const statusLabels = {
  planning: "構想中",
  active: "進行中",
  archived: "アーカイブ"
} as const;
---

<BaseLayout title="Projects" description="公開している制作物を、背景と現在地ごと一覧できるページ。">
  <Container className="py-16 sm:py-20">
    <section class="section-shell p-8 sm:p-10">
      <p class="eyebrow">Projects</p>
      <h1 class="mt-3 font-display text-4xl text-ink sm:text-5xl">制作物</h1>
      <p class="mt-5 max-w-3xl text-base leading-8 text-muted">
        公開しているプロジェクトを、何を作っているかだけでなく今どこまで進んでいるかも含めてまとめています。
      </p>
    </section>
  </Container>

  <Container className="pb-4">
    <div class="mx-auto max-w-5xl space-y-8" data-reveal-group>
      {
        projects.map((project) => (
          <article
            class="motion-card overflow-hidden rounded-[32px] border border-line/18 bg-[linear-gradient(180deg,rgba(255,255,255,0.045),rgba(255,255,255,0.028))] shadow-[0_26px_72px_rgba(3,8,20,0.2)]"
            data-reveal="card"
          >
            <div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
              <div class="p-8 sm:p-10">
                <div class="flex flex-wrap items-center gap-3 text-sm text-muted/78">
                  <span class="rounded-full border border-line/20 bg-white/[0.05] px-3 py-1 text-xs uppercase tracking-[0.18em]">
                    {statusLabels[project.data.status]}
                  </span>
                  <span>{formatDate(project.data.pubDate)}</span>
                </div>
                <h2 class="mt-5 font-display text-[2.8rem] leading-[1.02] tracking-[-0.03em] text-ink">
                  {project.data.title}
                </h2>
                <p class="mt-5 max-w-2xl text-base leading-8 text-muted">{project.data.summary}</p>
                <ul class="mt-7 flex flex-wrap gap-2">
                  {
                    project.data.technologies.map((item) => (
                      <li class="info-chip px-3 py-1 text-xs">{item}</li>
                    ))
                  }
                </ul>
                <div class="mt-8 flex flex-wrap gap-3">
                  <Button href={`/projects/${project.slug}/`}>詳細を見る</Button>
                  {hasVisibleRepoLink(project) && project.data.repoUrl && (
                    <Button href={project.data.repoUrl} variant="secondary">
                      {getRepoLinkLabel(project.data.repoUrl)}
                    </Button>
                  )}
                </div>
              </div>

              <div class="border-t border-line/12 p-4 lg:border-l lg:border-t-0 lg:p-5">
                <ProjectVisual
                  alt={`${project.data.title} のビジュアル`}
                  loading="eager"
                  src={project.data.overviewImage ?? project.data.coverImage}
                />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</BaseLayout>
