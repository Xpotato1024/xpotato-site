---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import Card from "../../components/ui/Card.astro";
import { getPublishedEntries } from "../../lib/content";

const notes = await getPublishedEntries("notes");
---

<BaseLayout title="Notes" description="講義補助や技術メモを蓄積するノート一覧。">
  <Container className="py-16">
    <SectionHeading
      eyebrow="Notes"
      title="ノート"
      description="教材メモや設計メモのような短い文書は、ブログと分けて軽量に保持します。"
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-2">
      {
        notes.map((note) => (
          <Card href={`/notes/${note.slug}/`}>
            <p class="text-sm text-ink/55">{note.data.subject}</p>
            <h3 class="mt-3 font-display text-2xl text-ink">{note.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-ink/72">{note.data.description}</p>
          </Card>
        ))
      }
    </div>
  </Container>
</BaseLayout>
