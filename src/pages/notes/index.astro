---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { getPublishedEntries } from "../../lib/content";

const notes = await getPublishedEntries("notes");
---

<BaseLayout title="学習資料" description="設計メモや手順書を、ブログより軽く参照できる形でまとめた一覧ページ。">
  <Container className="py-16 sm:py-20">
    <section class="section-shell p-8 sm:p-10">
      <p class="eyebrow">Learning</p>
      <h1 class="mt-3 font-display text-4xl text-ink sm:text-5xl">学習資料</h1>
      <p class="mt-5 max-w-3xl text-base leading-8 text-muted">
        設計メモや手順書を、ブログより軽く参照できる形でまとめています。
      </p>
    </section>
  </Container>

  <Container size="reading" className="space-y-4">
    {
      notes.map((note) => (
        <article class="rounded-[24px] border border-line/18 bg-white/[0.03] p-6 sm:p-7">
          <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.18em] text-muted/72">
            <span class="rounded-full border border-line/16 bg-white/[0.03] px-3 py-1">
              {note.data.subject}
            </span>
          </div>
          <h2 class="mt-4 font-display text-[2rem] leading-tight text-ink">{note.data.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{note.data.description}</p>
          <a
            class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-accent"
            href={`/notes/${note.slug}/`}
          >
            <span>開く</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))
    }
  </Container>
</BaseLayout>
