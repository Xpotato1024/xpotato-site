---
import { getCollection } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import { getRelatedBlogPosts } from "../../lib/content";
import { extractLegacyHeadings } from "../../lib/headings";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content, headings: renderedHeadings } = await entry.render();
const headings =
  renderedHeadings.length > 0
    ? renderedHeadings
    : extractLegacyHeadings((entry as { body?: string }).body ?? "");
const relatedPosts = await getRelatedBlogPosts(entry);
---

<BlogPostLayout
  entry={entry}
  pathname={`/blog/${entry.slug}/`}
  headings={headings}
  relatedPosts={relatedPosts}
>
  <Content />
</BlogPostLayout>
