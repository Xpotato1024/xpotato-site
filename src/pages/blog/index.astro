---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogArchive from "../../components/blog/BlogArchive.astro";
import { getPublishedEntries } from "../../lib/content";

const posts = await getPublishedEntries("blog");
---

<BaseLayout
  title="Blog"
  description="Xpotato のブログ記事を新着順で一覧できるページ。インフラ、ツール、雑記の入口もここにまとめています。"
>
  <BlogArchive activeCategory="all" allPosts={posts} posts={posts} />
</BaseLayout>
