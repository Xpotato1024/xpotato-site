---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import Hero from "../components/home/Hero.astro";
import ContentCategoryCard from "../components/home/ContentCategoryCard.astro";
import ProfileSummary from "../components/home/ProfileSummary.astro";
import ProjectCard from "../components/home/ProjectCard.astro";
import ArticleCard from "../components/blog/ArticleCard.astro";
import { getPublishedEntries } from "../lib/content";
import { filterBlogPosts } from "../lib/blog";

const blogPosts = await getPublishedEntries("blog");
const latestPosts = blogPosts.slice(0, 3);
const notes = await getPublishedEntries("notes");
const projects = await getPublishedEntries("projects");
const featuredProjectSource = projects.filter((project) => project.data.featured);
const featuredProjects =
  (featuredProjectSource.length > 0 ? featuredProjectSource : projects).slice(0, 3);
const toolPosts = filterBlogPosts(blogPosts, "tools");

const contentCategories = [
  {
    title: "Blog",
    description: "運用ログや技術メモを新着順で追えます。",
    href: "/blog/",
    icon: "BL",
    badge: "更新中",
    countLabel: `${blogPosts.length} 件`
  },
  {
    title: "制作物",
    description: "公開しているプロジェクトと背景の記録をまとめています。",
    href: "/projects/",
    icon: "PJ",
    badge: "公開物",
    countLabel: `${projects.length} 件`
  },
  {
    title: "学習資料",
    description: "手順書や検証メモを、後から参照しやすい形で整理しています。",
    href: "/notes/",
    icon: "LN",
    badge: "Docs",
    countLabel: `${notes.length} 件`
  },
  {
    title: "ツール",
    description: "ブラウザで触れる小さなツールや実験への入口です。",
    href: "/blog/category/tools/",
    icon: "TL",
    badge: "Labs",
    countLabel: `${toolPosts.length} 件`
  }
];
---

<BaseLayout
  title="Xpotato"
  description="ブログ、制作物、学習資料、ツールを横断して案内する Xpotato の総合入口ページ。"
>
  <Container className="py-16 sm:py-20">
    <Hero
      description="Xpotato の公開物を、迷わず見渡せる総合入口です。"
      items={["Blog", "制作物", "学習資料", "ツール"]}
      primaryCtaHref="#content-guide"
      primaryCtaLabel="コンテンツを見る"
      secondaryCtaHref="/blog/"
      secondaryCtaLabel="ブログを見る"
      title="ブログも、制作物も、学習資料も。ひとつの入口で辿れる。"
    />
  </Container>

  <section id="content-guide">
    <Container className="space-y-8">
      <SectionHeading
        actionHref="/blog/"
        actionLabel="更新一覧へ"
        eyebrow="Content Guide"
        title="サイト内の主要コンテンツ"
        description="4つの領域を、見た目と導線の両方で分かりやすく整理しています。"
      />
      <div class="grid gap-5 md:grid-cols-2">
        {contentCategories.map((item) => <ContentCategoryCard {...item} />)}
      </div>
    </Container>
  </section>

  <Container className="mt-20 space-y-8">
    <SectionHeading
      actionHref="/blog/"
      actionLabel="記事一覧へ"
      eyebrow="Latest Updates"
      title="最新の更新"
      description="新着記事を3件だけ絞って表示しています。"
    />
    <div class="grid gap-5 lg:grid-cols-3">
      {latestPosts.map((post) => <ArticleCard compact={true} post={post} />)}
    </div>
  </Container>

  <Container className="mt-20">
    <ProfileSummary
      bio={[
        "miyut として、WSL や自宅 RAG の検証、運用メモ、制作途中のログを少しずつ公開しています。",
        "成果だけでなく、途中の判断や失敗も後から辿れる形で残すことを大事にしています。"
      ]}
      links={[
        { href: "/about/", label: "About" },
        { href: "https://github.com/xpotato1024", label: "GitHub" },
        { href: "/projects/", label: "制作物一覧" }
      ]}
      name="miyut / Xpotato"
    />
  </Container>

  {
    featuredProjects.length > 0 && (
      <Container className="mt-20 space-y-8">
        <SectionHeading
          actionHref="/projects/"
          actionLabel="制作物一覧へ"
          eyebrow="Featured Projects"
          title="注目している制作物"
          description="ブログ以外の公開物もすぐ辿れるように前に出しています。"
        />
        <div
          class:list={[
            "gap-5",
            featuredProjects.length > 1 ? "grid lg:grid-cols-2" : "mx-auto max-w-4xl"
          ]}
        >
          {featuredProjects.map((project) => (
            <ProjectCard
              coverImage={project.data.coverImage}
              description={project.data.summary}
              href={`/projects/${project.slug}/`}
              status={project.data.status}
              techStack={project.data.technologies}
              title={project.data.title}
            />
          ))}
        </div>
      </Container>
    )
  }
</BaseLayout>
