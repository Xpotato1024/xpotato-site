---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout title="404" description="ページが見つかりませんでした。" noindex={true}>
  <Container className="py-24">
    <div class="surface p-10 text-center">
      <p class="eyebrow">404</p>
      <h1 class="mt-4 font-display text-5xl text-ink">Page Not Found</h1>
      <p class="mt-5 text-base text-ink/70">
        指定されたページは存在しないか、公開構成の整理により移動しました。
      </p>
      <a class="mt-8 inline-flex rounded-full bg-ink px-5 py-3 text-sm font-semibold text-paper" href="/">
        Home に戻る
      </a>
    </div>
  </Container>
</BaseLayout>
