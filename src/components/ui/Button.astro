---
interface Props {
  href: string;
  variant?: "primary" | "ghost";
}

const { href, variant = "primary" } = Astro.props;
const classes =
  variant === "primary"
    ? "bg-ink text-paper hover:bg-accent"
    : "border border-line bg-white/70 text-ink hover:border-accent/40 hover:text-accent";
---

<a
  class:list={[
    "inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-semibold transition-colors duration-200",
    classes
  ]}
  href={href}
>
  <slot />
</a>
