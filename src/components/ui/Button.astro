---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "sm";
}

const { href, variant = "primary", size = "md" } = Astro.props;
const isExternal = /^https?:\/\//.test(href);

const variantClasses = {
  primary: "button-shell--primary",
  secondary: "button-shell--secondary",
  ghost: "button-shell--ghost"
} as const;

const sizeClasses = {
  md: "min-h-[3.1rem] px-6 py-3 text-base",
  sm: "min-h-[2.85rem] px-5 py-2.5 text-sm"
} as const;
---

<a
  class:list={[
    "button-shell inline-flex items-center justify-center gap-2 font-semibold tracking-[0.01em] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper",
    variantClasses[variant],
    sizeClasses[size]
  ]}
  style="border-radius: var(--radius-button);"
  href={href}
  rel={isExternal ? "noreferrer" : undefined}
  target={isExternal ? "_blank" : undefined}
>
  <slot />
</a>
