---
interface Props {
  className?: string;
  size?: "page" | "reading" | "hero";
}

const { className = "", size = "page" } = Astro.props;
const sizeClasses = {
  page: "max-w-[1120px]",
  reading: "max-w-[760px]",
  hero: "max-w-[1080px]"
} as const;
---

<div class:list={["mx-auto w-full px-4 sm:px-6 lg:px-8", sizeClasses[size], className]}>
  <slot />
</div>
