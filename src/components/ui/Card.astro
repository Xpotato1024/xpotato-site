---
interface Props {
  href?: string;
  className?: string;
}

const { href, className = "" } = Astro.props;
const classes = [
  "block rounded-[24px] border border-line/20 bg-white/[0.06] p-6 shadow-panel backdrop-blur-xl transition-all duration-300",
  href &&
    "group hover:-translate-y-1 hover:border-accent/40 hover:bg-white/[0.08] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper",
  className
];
---

{
  href ? (
    <a class:list={classes} href={href}>
      <slot />
    </a>
  ) : (
    <div class:list={classes}>
      <slot />
    </div>
  )
}
