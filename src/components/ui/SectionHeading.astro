---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
}

const { eyebrow, title, description, actionLabel, actionHref } = Astro.props;
---

<div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
  <div class="max-w-3xl">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="mt-3 font-display text-3xl leading-tight text-ink sm:text-4xl">{title}</h2>
    {description && <p class="mt-4 max-w-2xl text-[0.98rem] leading-7 text-muted">{description}</p>}
  </div>
  {
    actionLabel &&
      actionHref && (
        <a
          class="info-chip shrink-0 hover:border-accent/40 hover:text-ink"
          href={actionHref}
        >
          <span>{actionLabel}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      )
  }
</div>
