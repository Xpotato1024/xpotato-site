---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 font-display text-3xl text-ink sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-ink/75">{description}</p>}
</div>
