---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
}

const { eyebrow, title, description, actionLabel, actionHref } = Astro.props;
---

<div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
  <div class="max-w-3xl">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="section-title">{title}</h2>
    {description && <p class="section-desc">{description}</p>}
  </div>
  {
    actionLabel &&
      actionHref && (
        <a class="section-link shrink-0" href={actionHref}>
          <span>{actionLabel}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      )
  }
</div>
