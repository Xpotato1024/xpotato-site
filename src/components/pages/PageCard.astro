---
import type { CollectionEntry } from "astro:content";
import Card from "../ui/Card.astro";
import { formatDate } from "../../lib/date";

interface Props {
  page: CollectionEntry<"pages">;
}

const { page } = Astro.props;
---

<Card href={`/${page.slug}/`}>
  <p class="text-sm text-ink/55">{formatDate(page.data.pubDate)}</p>
  <h3 class="mt-3 font-display text-2xl text-ink">{page.data.title}</h3>
  <p class="mt-3 text-sm leading-7 text-ink/72">
    {page.data.summary ?? page.data.description}
  </p>
</Card>
