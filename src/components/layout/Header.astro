---
import Container from "../ui/Container.astro";
import { siteConfig } from "../../lib/site-config";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }

  if (href === "/tools/") {
    return currentPath.startsWith("/tools/");
  }

  if (href === "/blog/") {
    return currentPath.startsWith("/blog/");
  }

  return currentPath === href || currentPath.startsWith(href);
}
---

<header data-site-header class="site-header sticky top-0 z-40 border-b border-line/10">
  <Container className="flex items-center justify-between py-4">
    <a class="font-display text-2xl font-semibold tracking-tight text-ink" href="/">
      {siteConfig.name}
    </a>

    <nav aria-label="Main navigation" class="hidden md:block">
      <ul class="flex flex-wrap items-center gap-7 text-sm font-medium">
        {
          siteConfig.navigation.map((item) => (
            <li>
              <a
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={["site-nav-link", isActive(item.href) && "is-active"]}
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <details class="site-mobile-menu relative md:hidden" data-mobile-menu>
      <summary class="site-mobile-menu-trigger inline-flex cursor-pointer list-none items-center gap-2 rounded-full px-4 py-2 text-sm font-medium text-ink">
        <span>Menu</span>
        <span aria-hidden="true" class="site-mobile-menu-trigger-icon">+</span>
      </summary>
      <nav
        aria-label="Mobile navigation"
        class="site-mobile-menu-panel absolute right-0 top-[calc(100%+0.75rem)] w-[min(18rem,calc(100vw-2rem))] p-3"
      >
        <ul class="flex flex-col gap-1 text-sm">
          {
            siteConfig.navigation.map((item) => (
              <li>
                <a
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    "site-mobile-menu-link flex items-center justify-between rounded-2xl px-4 py-3 transition-all duration-200",
                    isActive(item.href) && "is-active"
                  ]}
                  href={item.href}
                >
                  <span>{item.label}</span>
                  <span aria-hidden="true">&rarr;</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </Container>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  const mobileMenu = header?.querySelector("[data-mobile-menu]");

  if (header instanceof HTMLElement) {
    const syncHeaderState = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 12);
    };

    const closeMobileMenu = () => {
      if (mobileMenu instanceof HTMLDetailsElement) {
        mobileMenu.open = false;
      }
    };

    syncHeaderState();
    window.addEventListener("scroll", syncHeaderState, { passive: true });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMobileMenu);
    });

    document.addEventListener("click", (event) => {
      if (!(mobileMenu instanceof HTMLDetailsElement) || !(event.target instanceof Node)) return;
      if (!mobileMenu.contains(event.target)) {
        closeMobileMenu();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
        closeMobileMenu();
      }
    });
  }
</script>
