---
import Container from "../ui/Container.astro";
import { siteConfig } from "../../lib/site-config";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }

  if (href === "/tools/") {
    return currentPath.startsWith("/tools/");
  }

  if (href === "/blog/") {
    return currentPath.startsWith("/blog/");
  }

  return currentPath === href || currentPath.startsWith(href);
}
---

<header data-site-header class="site-header sticky top-0 z-40 border-b border-line/10 bg-paper/64">
  <Container className="flex items-center justify-between py-4">
    <a class="font-display text-2xl font-semibold tracking-tight text-ink" href="/">
      {siteConfig.name}
    </a>

    <nav aria-label="Main navigation" class="hidden md:block">
      <ul class="flex flex-wrap items-center gap-7 text-sm font-medium">
        {
          siteConfig.navigation.map((item) => (
            <li>
              <a
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "relative px-1.5 py-2 tracking-[0.01em] transition-colors duration-200 after:absolute after:bottom-0 after:left-1.5 after:right-1.5 after:h-px after:origin-left after:bg-accent/70 after:transition-transform after:duration-200",
                  isActive(item.href)
                    ? "text-ink after:scale-x-100"
                    : "text-muted/80 after:scale-x-0 hover:text-ink"
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <details class="relative md:hidden">
      <summary class="inline-flex cursor-pointer list-none items-center gap-2 rounded-full border border-white/[0.1] bg-white/[0.04] px-4 py-2 text-sm font-medium text-ink">
        <span>Menu</span>
        <span aria-hidden="true">+</span>
      </summary>
      <nav
        aria-label="Mobile navigation"
        class="surface-strong absolute right-0 top-[calc(100%+0.75rem)] w-[min(18rem,calc(100vw-2rem))] p-3"
      >
        <ul class="flex flex-col gap-1 text-sm">
          {
            siteConfig.navigation.map((item) => (
              <li>
                <a
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    "flex items-center justify-between rounded-2xl px-4 py-3 text-muted transition-all duration-200 hover:bg-white/[0.08] hover:text-ink",
                    isActive(item.href) && "bg-white/[0.1] text-ink"
                  ]}
                  href={item.href}
                >
                  <span>{item.label}</span>
                  <span aria-hidden="true">&rarr;</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </Container>
</header>

<script>
  const header = document.querySelector("[data-site-header]");

  if (header instanceof HTMLElement) {
    const syncHeaderState = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 12);
    };

    syncHeaderState();
    window.addEventListener("scroll", syncHeaderState, { passive: true });
  }
</script>
