---
import Container from "../ui/Container.astro";
import { siteConfig } from "../../lib/site-config";

const primaryLinks = siteConfig.footerNavigation.slice(0, 3);
const secondaryLinks = siteConfig.footerNavigation.slice(3);
---

<footer class="footer-site mt-24 border-t border-line/10">
  <Container className="py-12 sm:py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.9fr_0.7fr]">
      <div class="max-w-[24rem]">
        <p class="font-display text-[1.9rem] leading-none text-ink/94">{siteConfig.title}</p>
        <p class="mt-4 text-sm leading-7 text-muted/84">{siteConfig.tagline}</p>
        <p class="mt-8 text-xs uppercase tracking-[0.22em] text-muted/44">Astro + MDX + Tailwind</p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-muted/46">Navigation</p>
          <ul class="mt-4 space-y-3">
            {
              primaryLinks.map((item) => (
                <li>
                  <a class="footer-link" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-muted/46">More</p>
          <ul class="mt-4 space-y-3">
            {
              secondaryLinks.map((item) => (
                <li>
                  <a class="footer-link" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div>
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-muted/46">External</p>
        <a
          class="footer-link mt-4 inline-flex items-center gap-2"
          href={siteConfig.social.github}
          rel="noreferrer"
          target="_blank"
        >
          <span>GitHub</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </Container>
</footer>
