---
import ProjectVisual from "../project/ProjectVisual.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  techStack?: string[];
  status: "planning" | "active" | "archived";
  coverImage?: string;
}

const { title, description, href, techStack = [], status, coverImage } = Astro.props;

const statusLabels = {
  planning: "計画中",
  active: "進行中",
  archived: "アーカイブ"
} as const;
---

<a
  class="group block transition-all duration-300 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
  href={href}
>
  <ProjectVisual
    alt={`${title} のプレビュー`}
    className="transition-transform duration-500 group-hover:scale-[1.015]"
    loading="lazy"
    src={coverImage}
    variant="featured"
  />

  <div class="project-copy-panel mt-4 p-8 sm:p-10">
    <div class="relative z-10 flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.78rem] uppercase tracking-[0.14em] text-muted/58">
      <span>{statusLabels[status]}</span>
      {
        techStack.length > 0 && (
          <span class="contents">
            <span class="hidden h-1 w-1 rounded-full bg-white/16 sm:inline-block"></span>
            <span>{techStack.slice(0, 4).join(" / ")}</span>
          </span>
        )
      }
    </div>
    <h3 class="relative z-10 mt-4 font-display text-[clamp(1.9rem,3vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-ink/94">
      {title}
    </h3>
    <p class="relative z-10 mt-4 max-w-[62ch] text-[1rem] leading-[1.8] text-white/66">{description}</p>
    <p class="card-cta relative z-10 mt-7">
      <span>詳細を見る</span>
      <span aria-hidden="true">&rarr;</span>
    </p>
  </div>
</a>
