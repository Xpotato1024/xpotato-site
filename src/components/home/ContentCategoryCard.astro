---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
  countLabel?: string;
}

const { title, description, href, icon, badge, countLabel } = Astro.props;
---

<a
  class="refined-card refined-card--quiet motion-card group block p-7 sm:p-8 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
  href={href}
  data-reveal="card"
>
  <div class="flex items-start justify-between gap-4">
    <span class="inline-flex h-10 w-10 items-center justify-center bg-white/[0.03] text-[0.72rem] font-semibold tracking-[0.18em] text-ink/82" style="border-radius: var(--radius-button);">
      {icon}
    </span>
    {badge && <span class="text-[0.76rem] font-semibold uppercase tracking-[0.16em] text-muted/50">{badge}</span>}
  </div>

  <h3 class="card-title mt-5 text-[clamp(1.45rem,2.2vw,1.62rem)]">{title}</h3>
  <p class="card-desc mt-4 max-w-[30rem]">{description}</p>

  <div class="card-footer mt-6 flex items-center justify-between text-sm">
    <span class="text-muted/56">{countLabel}</span>
    <span class="card-cta">
      <span>開く</span>
      <span aria-hidden="true">&rarr;</span>
    </span>
  </div>
</a>
