---
interface Link {
  href: string;
  label: string;
}

interface Props {
  name: string;
  bio: string[];
  links: Link[];
}

const { name, bio, links } = Astro.props;
---

<section class="bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.008))] p-8 shadow-[0_18px_48px_rgba(3,8,20,0.14)] sm:p-10" style="border-radius: var(--radius-card);">
  <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr]">
    <div>
      <p class="eyebrow">Profile</p>
      <h2 class="mt-3 font-display text-[clamp(2rem,3.3vw,2.5rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-ink/92">
        {name}
      </h2>
    </div>
    <div>
      <div class="max-w-[62ch] space-y-4 text-[1.03rem] leading-[1.84] text-white/68 sm:text-[1.08rem]">
        {bio.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="mt-7 flex flex-wrap gap-x-6 gap-y-2">
        {
          links.map((link) => (
            <a class="card-cta" href={link.href}>
              <span>{link.label}</span>
              <span aria-hidden="true">&rarr;</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
