---
import Button from "../ui/Button.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  titleLines?: string[];
  description: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  items?: string[];
}

const {
  eyebrow = "Xpotato",
  title,
  titleLines = [],
  description,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  items = []
} = Astro.props;
---

<section class="glass-stage hero-stage px-7 py-14 sm:px-12 sm:py-20">
  <div aria-hidden="true" class="ambient-noise ambient-noise--hero"></div>
  <div class="relative max-w-[720px]">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-5 max-w-[8.6ch] font-display text-[clamp(3.5rem,8vw,5.5rem)] font-bold leading-[0.97] tracking-[-0.04em] text-ink/95">
      {
        titleLines.length > 0 ? (
          titleLines.map((line) => <span class="block">{line}</span>)
        ) : (
          title
        )
      }
    </h1>
    <p class="mt-7 max-w-[31ch] text-[1.22rem] leading-[1.68] text-muted/88 sm:text-[1.28rem]">
      {description}
    </p>

    <div class="glass-panel hero-cta-panel mt-11 max-w-[38rem] p-5 sm:p-6">
      <div class="relative z-10 flex flex-col gap-3 sm:flex-row">
        <Button href={primaryCtaHref}>{primaryCtaLabel}</Button>
        {
          secondaryCtaLabel &&
            secondaryCtaHref && (
              <Button href={secondaryCtaHref} variant="secondary">
                {secondaryCtaLabel}
              </Button>
            )
        }
      </div>

      {
        items.length > 0 && (
          <ul class="relative z-10 mt-4 flex flex-wrap gap-x-4 gap-y-1.5 text-[0.84rem] text-muted/72">
            {
              items.map((item) => (
                <li class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent/70"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        )
      }
    </div>
  </div>
</section>
