---
import ProjectVisual from "../project/ProjectVisual.astro";
import type { ToolEntry } from "../../lib/tools";
import { formatDate } from "../../lib/date";
import { getToolCategoryKey, getToolCategoryLabel } from "../../lib/tools";

interface Props {
  tool: ToolEntry;
}

const { tool } = Astro.props;
const categoryKey = getToolCategoryKey(tool);
const categoryLabel = getToolCategoryLabel(categoryKey);
const visibleTags = tool.data.tags.slice(0, 4);
const latestDate = tool.data.updatedDate ?? tool.data.pubDate;
---

<article class="overflow-hidden rounded-[32px] border border-line/18 bg-[linear-gradient(180deg,rgba(255,255,255,0.045),rgba(255,255,255,0.028))] shadow-[0_24px_64px_rgba(3,8,20,0.18)]">
  <a class="grid gap-0 lg:grid-cols-[0.9fr_1.1fr]" href={`/tools/${tool.slug}/`}>
    <div class="border-b border-line/12 p-4 lg:border-b-0 lg:border-r">
      <ProjectVisual alt={`${tool.data.title} のプレビュー`} loading="lazy" src={tool.data.previewImage} />
    </div>

    <div class="p-6 sm:p-8">
      <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.18em] text-muted/72">
        <span class="rounded-full border border-line/16 bg-white/[0.03] px-3 py-1 text-[0.68rem]">
          {categoryLabel}
        </span>
        <time datetime={latestDate.toISOString()}>{formatDate(latestDate)}</time>
      </div>

      <h3 class="mt-5 font-display text-[2.2rem] leading-[1.06] tracking-[-0.03em] text-ink">
        {tool.data.title}
      </h3>
      <p class="mt-4 max-w-2xl text-sm leading-8 text-muted">{tool.data.summary}</p>

      {
        visibleTags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {
              visibleTags.map((tag) => (
                <li class="rounded-full border border-line/14 bg-transparent px-3 py-1 text-[0.7rem] text-muted/74">
                  {tag}
                </li>
              ))
            }
          </ul>
        )
      }

      <div class="mt-7 text-sm font-medium text-accent">
        触ってみる
        <span aria-hidden="true">&rarr;</span>
      </div>
    </div>
  </a>
</article>
