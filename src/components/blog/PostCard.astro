---
import type { CollectionEntry } from "astro:content";
import Card from "../ui/Card.astro";
import { formatDate } from "../../lib/date";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<Card href={`/blog/${post.slug}/`}>
  <p class="text-sm text-ink/55">{formatDate(post.data.pubDate)}</p>
  <h3 class="mt-3 font-display text-2xl text-ink">{post.data.title}</h3>
  <p class="mt-3 text-sm leading-7 text-ink/72">{post.data.description}</p>
  {
    post.data.tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => <li class="rounded-full bg-accent/10 px-3 py-1 text-xs text-accent">{tag}</li>)}
      </ul>
    )
  }
</Card>
