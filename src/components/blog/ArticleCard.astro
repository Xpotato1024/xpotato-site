---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../lib/date";
import { getBlogCategoryKey, getBlogCategoryLabel } from "../../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const categoryKey = getBlogCategoryKey(post);
const categoryLabel = getBlogCategoryLabel(categoryKey);
const visibleTags = post.data.tags.slice(0, compact ? 3 : 5);
const actionLabel = categoryKey === "tools" ? "触ってみる" : "続きを読む";
---

<article
  class:list={[
    compact
      ? "rounded-[24px] border border-line/18 bg-white/[0.03] transition-all duration-300 hover:-translate-y-1 hover:border-accent/35 hover:bg-white/[0.045] hover:shadow-[0_18px_48px_rgba(3,8,20,0.16)]"
      : "rounded-[24px] border border-line/16 bg-transparent transition-all duration-300 hover:border-accent/28 hover:bg-white/[0.02] hover:shadow-[0_16px_42px_rgba(3,8,20,0.12)]",
    "overflow-hidden"
  ]}
  data-category={categoryKey}
>
  <a
    class:list={[
      "block h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper",
      compact ? "p-6" : "p-6 sm:p-7"
    ]}
    href={`/blog/${post.slug}/`}
  >
    <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.18em] text-muted/72">
      <span class="rounded-full border border-line/16 bg-white/[0.03] px-3 py-1 text-[0.68rem]">
        {categoryLabel}
      </span>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </div>

    <h3
      class:list={[
        "mt-4 font-display text-ink",
        compact ? "text-[1.85rem] leading-[1.12]" : "text-[2.2rem] leading-[1.12] sm:text-[2.35rem]"
      ]}
    >
      {post.data.title}
    </h3>
    <p class="mt-4 max-w-3xl overflow-hidden text-[0.98rem] leading-8 text-muted [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">
      {post.data.description}
    </p>

    {
      visibleTags.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2">
          {
            visibleTags.map((tag) => (
              <li class="rounded-full border border-line/14 bg-transparent px-3 py-1 text-[0.7rem] text-muted/74">
                {tag}
              </li>
            ))
          }
        </ul>
      )
    }

    <div class="mt-6 text-sm font-medium text-accent">
      {actionLabel}
      <span aria-hidden="true">&rarr;</span>
    </div>
  </a>
</article>
