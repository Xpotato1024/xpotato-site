---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../lib/date";
import { getBlogCategoryKey, getBlogCategoryLabel } from "../../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const categoryKey = getBlogCategoryKey(post);
const categoryLabel = getBlogCategoryLabel(categoryKey);
const visibleTags = post.data.tags.slice(0, compact ? 3 : 5);
const actionLabel = "続きを読む";
---

<article
  class:list={[
    compact ? "refined-card refined-card--elevated" : "refined-card refined-card--quiet",
    "overflow-hidden"
  ]}
  data-category={categoryKey}
>
  <a
    class:list={[
      "group block h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-paper",
      compact ? "p-7 sm:p-8" : "p-7 sm:p-8"
    ]}
    href={`/blog/${post.slug}/`}
  >
    <div class="card-meta">
      <span class="card-tag card-tag--strong">
        {categoryLabel}
      </span>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </div>

    <h3
      class:list={[
        "card-title mt-4",
        compact ? "text-[clamp(1.375rem,2vw,1.5rem)]" : "text-[clamp(1.45rem,2.2vw,1.62rem)]"
      ]}
    >
      {post.data.title}
    </h3>
    <p class="card-desc mt-4 max-w-[62ch] overflow-hidden [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:3]">
      {post.data.description}
    </p>

    {
      visibleTags.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2">
          {
            visibleTags.map((tag) => (
              <li class="card-tag">
                {tag}
              </li>
            ))
          }
        </ul>
      )
    }

    <div class="card-cta card-footer">
      <span>{actionLabel}</span>
      <span aria-hidden="true">&rarr;</span>
    </div>
  </a>
</article>
