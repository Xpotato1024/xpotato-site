---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{
  tocHeadings.length > 0 && (
    <section class="surface p-5">
      <p class="eyebrow">Contents</p>
      <h2 class="mt-3 font-display text-2xl text-ink">目次</h2>
      <nav class="mt-5" aria-label="Table of contents">
        <ol class="space-y-2 text-sm leading-7 text-ink/72">
          {tocHeadings.map((heading) => (
            <li class:list={[heading.depth > 2 && "pl-4"]}>
              <a class="hover:text-accent" href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </section>
  )
}
