---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import SEO from "../components/seo/SEO.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const props = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <SEO {...props} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        if (typeof window === "undefined") return;

        const root = document.documentElement;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        const ambientTargets = document.querySelector(".hero-stage, .project-visual, .page-section");

        if (!ambientTargets) return;

        const reset = () => {
          [
            "--hero-blue-shift-x",
            "--hero-blue-shift-y",
            "--hero-red-shift-y",
            "--hero-violet-shift-y",
            "--hero-stage-shift-x",
            "--hero-stage-shift-y",
            "--featured-blue-shift-x",
            "--featured-blue-shift-y",
            "--featured-red-shift-y",
            "--featured-violet-shift-y",
            "--section-subtle-shift-x",
            "--section-subtle-shift-y"
          ].forEach((name) => root.style.setProperty(name, "0px"));
        };

        if (reduceMotion.matches) {
          reset();
          return;
        }

        let frame = 0;
        let currentY = window.scrollY;
        let targetY = window.scrollY;

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        const write = () => {
          currentY += (targetY - currentY) * 0.07;

          root.style.setProperty("--hero-blue-shift-x", `${clamp(currentY * 0.01, 0, 5).toFixed(2)}px`);
          root.style.setProperty("--hero-blue-shift-y", `${clamp(currentY * 0.026, 0, 12).toFixed(2)}px`);
          root.style.setProperty("--hero-red-shift-y", `${clamp(currentY * -0.016, -8, 0).toFixed(2)}px`);
          root.style.setProperty("--hero-violet-shift-y", `${clamp(currentY * 0.01, 0, 4).toFixed(2)}px`);
          root.style.setProperty("--hero-stage-shift-x", `${clamp(currentY * -0.004, -3, 0).toFixed(2)}px`);
          root.style.setProperty("--hero-stage-shift-y", `${clamp(currentY * 0.008, 0, 4).toFixed(2)}px`);
          root.style.setProperty("--featured-blue-shift-x", `${clamp(currentY * 0.007, 0, 3).toFixed(2)}px`);
          root.style.setProperty("--featured-blue-shift-y", `${clamp(currentY * 0.016, 0, 8).toFixed(2)}px`);
          root.style.setProperty("--featured-red-shift-y", `${clamp(currentY * -0.012, -6, 0).toFixed(2)}px`);
          root.style.setProperty("--featured-violet-shift-y", `${clamp(currentY * 0.008, 0, 4).toFixed(2)}px`);
          root.style.setProperty("--section-subtle-shift-x", `${clamp(currentY * 0.003, 0, 1.5).toFixed(2)}px`);
          root.style.setProperty("--section-subtle-shift-y", `${clamp(currentY * 0.007, 0, 4).toFixed(2)}px`);

          if (Math.abs(targetY - currentY) > 0.1) {
            frame = window.requestAnimationFrame(write);
          } else {
            frame = 0;
          }
        };

        const onScroll = () => {
          targetY = window.scrollY;

          if (!frame) {
            frame = window.requestAnimationFrame(write);
          }
        };

        const onPreferenceChange = (event) => {
          if (event.matches) {
            if (frame) window.cancelAnimationFrame(frame);
            frame = 0;
            reset();
            return;
          }

          currentY = window.scrollY;
          targetY = window.scrollY;
          onScroll();
        };

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
        reduceMotion.addEventListener?.("change", onPreferenceChange);
      })();
    </script>
  </body>
</html>
